{
  "name": "tuzluca-social",
  "private": true,
  "version": "0.0.9",
  "description": "Tuzluca Social - A Web-Based Desktop Operating System Concept",
  "author": "Tuzluca Cloud Inc.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "vite:dev": "vite --host",
    "dev": "concurrently -k \"npm run vite:dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "build:exe": "vite build && electron-builder -w",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.tuzlucasocial.app",
    "productName": "Tuzluca Social",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2",
    "vite": "^8.0.12",
    "vite-plugin-node-polyfills": "^0.28.0",
    "wait-on": "^9.0.10"
  }
}
